// Calculate electricity bill using slabs
#include<stdio.h>
int main(){
    int units;
    float bill;
    printf("Enter electricity units: ");
    scanf("%d", &units);
    if(units <= 100){
        bill = units * 5;
    }
    else if(units <= 200){

        bill = (100 * 5) + (units - 100) * 8 ;
    }
    else {
        bill = (100 * 5) + (100 * 8) + (units - 200) * 10 ;
    }
    printf("Total Electricity Bill = %.2f\n", bill);    
    return 0;
}
